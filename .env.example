# Nexo Database Configuration
# All values have sensible defaults — override only what you need.

# SurrealDB connection URL
# Docker Compose: http://localhost:8000
# Warden:         https://db.nexo.test
# Direct install: http://localhost:8000
NEXO_DB_URL=http://localhost:8000

# SurrealDB namespace and database
NEXO_DB_NS=nexo
NEXO_DB_DB=nexo

# SurrealDB credentials
NEXO_DB_USER=root
NEXO_DB_PASS=root
